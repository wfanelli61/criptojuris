# Database (PostgreSQL via Docker Compose)
DATABASE_URL="postgresql://abogados_user:abogados_pass@localhost:5432/abogados_db?schema=public"

# JWT
JWT_SECRET="dev-jwt-secret-change-in-production-2024"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production-2024"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Backend
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# SMTP (Gmail example - use App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM="BufeteLegal <noreply@bufetelegal.com>"
